{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "ml_service/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/ml/(.*)",
      "dest": "ml_service/main.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ]
}
